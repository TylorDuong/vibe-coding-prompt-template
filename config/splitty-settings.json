{
  "splittyPresetVersion": 1,
  "app": "splitty-ai v0.2.0",
  "pipelineConfig": {
    "silenceThresholdDb": -40,
    "minSilenceDurationMs": 800,
    "paddingMs": 200,
    "mergeGapMs": 300,
    "minKeepMs": 150,
    "attentionLengthMs": 3000,
    "maxWords": 3,
    "graphicWidthPercent": 30,
    "captionFontSize": 56,
    "captionFontColor": "#fff700",
    "captionOutlineColor": "#000000",
    "captionPosition": "center",
    "captionBold": true,
    "captionBox": false,
    "captionBorderWidth": 3,
    "captionFadeInSec": 0.05,
    "captionFadeOutSec": 0.05,
    "graphicPosition": "center",
    "graphicMotion": "slide_in",
    "graphicAnimInSec": 0.05,
    "sfxCaptionEveryN": 0,
    "sfxGraphicEveryN": 1,
    "graphicFadeInSec": 0,
    "graphicFadeOutSec": 0,
    "faceZoomEnabled": true,
    "faceZoomIntervalSec": 6,
    "faceZoomPulseSec": 3,
    "faceZoomStrength": 0.2,
    "outputAspectRatio": "9:16",
    "videoSpeed": 1.65
  }
}
